# RankFlow runtime mode
# local: normal development
# staging/demo deploy with seeded data: NODE_ENV=production + RANKFLOW_DATA_MODE=seed
# true customer production: NODE_ENV=production + RANKFLOW_DATA_MODE=live with a real repository wired
NODE_ENV=development
RANKFLOW_DATA_MODE=seed

# Service URLs
PORT=4000
CORS_ORIGIN=http://127.0.0.1:3000
RANKFLOW_API_URL=http://127.0.0.1:4000

# Future Supabase production repository
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Google Search Console live connector
RANKFLOW_GSC_LIVE_MODE=0
RANKFLOW_GSC_SITE_URL=
RANKFLOW_GSC_ACCESS_TOKEN=

# Google Analytics 4 live connector
RANKFLOW_GA4_LIVE_MODE=0
RANKFLOW_GA4_PROPERTY_ID=
RANKFLOW_GA4_ACCESS_TOKEN=

# Authority/rank live connectors
RANKFLOW_DATAFORSEO_LIVE_MODE=0
RANKFLOW_DATAFORSEO_LOGIN=
RANKFLOW_DATAFORSEO_PASSWORD=
RANKFLOW_DATAFORSEO_LOCATION_NAME=United States
RANKFLOW_DATAFORSEO_LANGUAGE_NAME=English
RANKFLOW_AHREFS_LIVE_MODE=0
RANKFLOW_AHREFS_API_KEY=
RANKFLOW_SEMRUSH_LIVE_MODE=0
RANKFLOW_SEMRUSH_API_KEY=
RANKFLOW_SEMRUSH_DATABASE=us

# Claude SEO Brain live connector
RANKFLOW_CLAUDE_BRAIN_LIVE_MODE=0
RANKFLOW_CLAUDE_BRAIN_API_KEY=
RANKFLOW_CLAUDE_BRAIN_MODEL=claude-sonnet-4-20250514
